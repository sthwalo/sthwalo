<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite requests to the /app/ subdirectory (FIN dashboard)
  RewriteRule ^app(/|$) - [L]

  # Don't rewrite requests to the /api/ (Node.js contact API)
  RewriteRule ^api(/|$) - [L]

  # Don't rewrite actual files or directories
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Send everything else to index.html for React Router
  RewriteRule . /index.html [L]
</IfModule>
